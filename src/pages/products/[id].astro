---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { allProducts, waLink, contact } from '../../data/products';
import type { Product } from '../../data/products';
import { specs, catalogByLine } from '../../data/specs';
import { gallery } from '../../data/gallery';

export function getStaticPaths() {
  return allProducts.map(product => ({
    params: { id: product.id },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const enquireUrl = waLink(product.enquiryText);
const specRows = specs[product.id] ?? [];
const catalog = catalogByLine[product.line];
const images = gallery[product.id] ?? [product.image];
// Approximate width of the product name in em (DM Sans bold caps ≈ 0.74em/char),
// used to size the H1 so it always fits on one line.
const nameEm = (product.name.length * 0.74).toFixed(2);
const telHref = `tel:${contact.hotline.replace(/\s/g, '')}`;
const mailHref = `mailto:${contact.email}`;

const phoneIcon = `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>`;
const mailIcon = `<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>`;

const spaceStyle: Record<string, string> = {
  residential: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/25',
  commercial:  'text-cyan-400 bg-cyan-500/10 border-cyan-500/25',
  industrial:  'text-amber-400 bg-amber-500/10 border-amber-500/25',
};
const spaceLabel: Record<string, string> = {
  residential: 'Residential',
  commercial:  'Commercial',
  industrial:  'Industrial',
};

// Up to 3 related products from the same line, else pad from others
const sameLineOthers = allProducts.filter(p => p.line === product.line && p.id !== product.id);
const otherPool      = allProducts.filter(p => p.id !== product.id && p.line !== product.line);
const related = [...sameLineOthers, ...otherPool].slice(0, 3);

const waIcon = `<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>`;
---

<Layout
  title={`${product.name} — ${product.tagline} | DryTech.sg`}
  description={`${product.name}: ${product.description} Available from DryTech.sg, Singapore's ceiling dehumidifier specialist.`}
>
  <Nav />
  <main>

    <!-- ── Product hero ──────────────────────────────────────────── -->
    <section class="bg-dt-950 pt-24 pb-0 overflow-hidden relative">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
        style="background-image:radial-gradient(circle,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:28px 28px;"></div>

      <div class="max-w-7xl mx-auto px-6">

        <!-- Breadcrumb -->
        <nav class="mb-10 flex items-center gap-2 text-white/30 text-xs font-mono" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white/60 transition-colors">DryTech.sg</a>
          <span aria-hidden="true">/</span>
          <a href="/#products" class="hover:text-white/60 transition-colors">Products</a>
          <span aria-hidden="true">/</span>
          <span class="text-white/55">{product.name}</span>
        </nav>

        <div class="grid lg:grid-cols-2 gap-10 lg:gap-20 items-start pb-20">

          <!-- Left: product info -->
          <div class="order-2 lg:order-1 min-w-0 lg:pt-10">
            <div class="flex flex-wrap items-center gap-3 mb-5">
              <span class="text-[10px] font-mono tracking-[0.2em] uppercase text-cyan-500/80">{product.line}</span>
              <span class="w-px h-3 bg-white/20" aria-hidden="true"></span>
              <span class="font-mono text-sm font-bold text-cyan-300">{product.capacity}</span>
            </div>

            <h1 class="product-title font-sans font-bold text-white leading-none tracking-tight mb-5 whitespace-nowrap"
              style={`--name-em:${nameEm};`}>
              {product.name}
            </h1>

            <p class="text-white/50 text-base sm:text-lg leading-relaxed mb-7 max-w-lg">
              {product.tagline}
            </p>

            <div class="flex flex-wrap gap-2 mb-10">
              {product.bestFor.map(s => (
                <span class={`text-xs font-semibold px-3 py-1 rounded-full border ${spaceStyle[s] ?? 'text-white/50 bg-white/5 border-white/15'}`}>
                  {spaceLabel[s] ?? s}
                </span>
              ))}
            </div>

            <div class="flex flex-wrap items-center gap-3">
              <a
                href={enquireUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2.5 bg-cyan-600 hover:bg-cyan-500 text-white font-semibold px-7 py-3.5 rounded-full transition-colors text-sm"
              >
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={waIcon}></svg>
                Enquire on WhatsApp
              </a>
              <a
                href={telHref}
                class="inline-flex items-center gap-2.5 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold px-6 py-3.5 rounded-full transition-colors text-sm"
              >
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true" set:html={phoneIcon}></svg>
                {contact.hotline}
              </a>
              <a
                href={mailHref}
                class="inline-flex items-center gap-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold px-6 py-3.5 rounded-full transition-colors text-sm"
              >
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true" set:html={mailIcon}></svg>
                Email us
              </a>
            </div>
          </div>

          <!-- Right: product image gallery on white panel -->
          <div class="order-1 lg:order-2 flex items-center justify-center min-w-0">
            <div class="relative w-full max-w-sm sm:max-w-md lg:max-w-none">
              <div class="absolute inset-[-20%] bg-cyan-500/8 rounded-full blur-3xl" aria-hidden="true"></div>
              <div class="relative bg-white rounded-3xl aspect-square flex items-center justify-center p-10 sm:p-14 shadow-[0_24px_64px_-12px_rgba(0,0,0,0.55)]">
                <img
                  id="product-main-img"
                  src={images[0]}
                  alt={product.name}
                  class="w-full h-full object-contain"
                  style="mix-blend-mode:multiply;"
                  loading="eager"
                  decoding="async"
                />
              </div>
              {images.length > 1 && (
                <div class="relative mt-4" aria-label="Product photos">
                  <button
                    type="button"
                    id="thumb-prev"
                    aria-label="Previous photos"
                    class="absolute -left-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white text-slate-700 shadow-lg flex items-center justify-center hover:bg-cyan-500 hover:text-white transition-colors"
                  >
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                  </button>
                  <div id="thumb-strip" class="flex gap-2.5 overflow-x-auto scroll-smooth snap-x pb-1 px-1 scrollbar-hide">
                    {images.map((src, i) => (
                      <button
                        type="button"
                        data-thumb={src}
                        aria-label={`Photo ${i + 1} of ${product.name}`}
                        class={`thumb-btn shrink-0 w-16 h-16 sm:w-[76px] sm:h-[76px] bg-white rounded-xl p-1.5 snap-start cursor-pointer transition-all duration-200 ring-cyan-400 hover:ring-2 hover:-translate-y-1 hover:shadow-[0_8px_20px_-6px_rgba(34,211,238,0.5)] ${i === 0 ? 'ring-2' : 'opacity-70 hover:opacity-100'}`}
                      >
                        <img
                          src={src}
                          alt=""
                          class="w-full h-full object-contain pointer-events-none"
                          style="mix-blend-mode:multiply;"
                          loading="lazy"
                          decoding="async"
                        />
                      </button>
                    ))}
                  </div>
                  <button
                    type="button"
                    id="thumb-next"
                    aria-label="Next photos"
                    class="absolute -right-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white text-slate-700 shadow-lg flex items-center justify-center hover:bg-cyan-500 hover:text-white transition-colors"
                  >
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                  </button>
                </div>
              )}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Specs + enquiry ───────────────────────────────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-[1fr_360px] gap-12 lg:gap-16 items-start">

        <!-- Left: description + highlights -->
        <div>
          <h2 class="font-display font-bold text-slate-900 text-2xl mb-4">About this unit</h2>
          <p class="text-slate-500 text-base leading-relaxed mb-12 max-w-prose">
            {product.description}
          </p>

          <p class="text-[10px] font-mono tracking-[0.22em] uppercase text-slate-400 mb-5">Highlights</p>
          <ul class="space-y-4 mb-12">
            {product.highlights.map(h => (
              <li class="flex items-start gap-4">
                <div class="shrink-0 w-6 h-6 rounded-full bg-cyan-100 flex items-center justify-center mt-0.5">
                  <svg width="11" height="11" fill="none" stroke="#0891b2" stroke-width="2.5" viewBox="0 0 12 12" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/>
                  </svg>
                </div>
                <span class="text-slate-700 text-sm leading-relaxed">{h}</span>
              </li>
            ))}
          </ul>

          {specRows.length > 0 && (
            <div class="mb-12">
              <p class="text-[10px] font-mono tracking-[0.22em] uppercase text-slate-400 mb-5">Full specifications</p>
              <div class="rounded-2xl border border-slate-200 overflow-hidden">
                <table class="w-full text-sm">
                  <tbody>
                    {specRows.map(([label, value], i) => (
                      <tr class={i % 2 === 0 ? 'bg-slate-50/60' : 'bg-white'}>
                        <th scope="row" class="text-left font-medium text-slate-500 px-5 py-3 w-1/2 align-top">{label}</th>
                        <td class="text-slate-900 font-medium px-5 py-3">{value}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          <!-- Source link -->
          <a
            href={product.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-slate-400 hover:text-slate-700 text-sm transition-colors"
          >
            Full spec sheet on DBA.sg
            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>

        <!-- Right: sticky enquiry card -->
        <div class="lg:sticky lg:top-24 space-y-3">
          <div class="bg-dt-950 rounded-2xl p-7">
            <h3 class="font-display font-bold text-white text-lg mb-2">Interested in the {product.name}?</h3>
            <p class="text-white/40 text-sm leading-relaxed mb-6">
              Get a no-obligation quote. We'll confirm sizing, ducting options and pricing for your space.
            </p>
            <a
              href={enquireUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white font-semibold px-5 py-3.5 rounded-xl transition-colors text-sm w-full mb-3"
            >
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={waIcon}></svg>
              Enquire on WhatsApp
            </a>
            <a
              href={telHref}
              class="flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold px-5 py-3 rounded-xl transition-colors text-sm w-full mb-3"
            >
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true" set:html={phoneIcon}></svg>
              Call {contact.hotline}
            </a>
            <a
              href={mailHref}
              class="flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold px-5 py-3 rounded-xl transition-colors text-sm w-full"
            >
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true" set:html={mailIcon}></svg>
              {contact.email}
            </a>
          </div>

          {catalog && (
            <a
              href={catalog.file}
              target="_blank"
              rel="noopener noreferrer"
              download
              class="group hidden lg:block bg-white border-2 border-cyan-500/40 hover:border-cyan-500 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200"
            >
              <div class="flex items-center gap-4 p-4">
                <div class="shrink-0 w-20 aspect-[3/4] rounded-lg overflow-hidden bg-slate-100 shadow-md group-hover:scale-[1.03] transition-transform duration-300">
                  <img
                    src={catalog.thumb}
                    alt={`${catalog.title} cover`}
                    class="w-full h-full object-cover object-top"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="min-w-0">
                  <p class="text-[10px] font-bold tracking-[0.16em] uppercase text-cyan-600 mb-1">Product catalog</p>
                  <div class="font-sans font-bold text-slate-900 text-sm leading-snug">{catalog.title}</div>
                  <p class="text-slate-400 text-xs mt-1">Full specs &amp; drawings (PDF)</p>
                </div>
              </div>
              <div class="flex items-center justify-center gap-2 bg-cyan-600 group-hover:bg-cyan-500 text-white text-sm font-semibold py-3 transition-colors">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4 4-4M4 20h16"/>
                </svg>
                Download PDF Catalog
              </div>
            </a>
          )}

          <a
            href="/#products"
            class="flex items-center justify-center gap-2 border border-slate-200 hover:border-slate-300 text-slate-500 hover:text-slate-700 text-sm font-medium px-5 py-3 rounded-xl transition-colors w-full"
          >
            ← Browse all products
          </a>
        </div>

      </div>
    </section>

    <!-- ── Catalog download band ────────────────────────────────── -->
    {catalog && (
      <section class="py-16 bg-dt-950 relative overflow-hidden">
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
          style="background-image:radial-gradient(circle,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:28px 28px;"></div>
        <div class="max-w-7xl mx-auto px-6 relative">
          <div class="flex flex-col sm:flex-row items-center gap-8 sm:gap-12">

            <a href={catalog.file} target="_blank" rel="noopener noreferrer" download
              class="group shrink-0 relative"
              aria-label={`Download the ${catalog.title}`}>
              <div class="absolute inset-[-15%] bg-cyan-500/15 rounded-full blur-3xl" aria-hidden="true"></div>
              <img
                src={catalog.thumb}
                alt={`${catalog.title} cover`}
                class="relative w-40 sm:w-48 rounded-xl shadow-[0_20px_50px_-12px_rgba(0,0,0,0.7)] group-hover:scale-[1.04] group-hover:-rotate-1 transition-transform duration-300"
                loading="lazy"
                decoding="async"
              />
            </a>

            <div class="text-center sm:text-left">
              <p class="text-xs font-semibold tracking-[0.16em] uppercase text-cyan-400 mb-3">Free download</p>
              <h2 class="font-display font-bold text-white text-2xl sm:text-3xl leading-tight mb-3">
                {catalog.title}
              </h2>
              <p class="text-white/50 text-base leading-relaxed mb-7 max-w-xl">
                Full specifications, dimensions, installation drawings and performance data
                for the complete {product.line} range — including the {product.name}.
              </p>
              <div class="flex flex-wrap items-center justify-center sm:justify-start gap-4">
                <a
                  href={catalog.file}
                  target="_blank"
                  rel="noopener noreferrer"
                  download
                  class="inline-flex items-center gap-2.5 bg-cyan-600 hover:bg-cyan-500 text-white font-semibold px-7 py-3.5 rounded-full transition-colors text-sm"
                >
                  <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4 4-4M4 20h16"/>
                  </svg>
                  Download PDF Catalog
                </a>
                <a href="/#catalogs" class="text-white/50 hover:text-white text-sm font-medium transition-colors">
                  View all catalogs →
                </a>
              </div>
            </div>

          </div>
        </div>
      </section>
    )}

    <!-- ── Related products ─────────────────────────────────────── -->
    {related.length > 0 && (
      <section class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-6">
          <h2 class="font-display font-bold text-slate-900 text-xl mb-8">More DBA ceiling dehumidifiers</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {related.map(p => (
              <a
                href={`/products/${p.id}`}
                class="group bg-white rounded-2xl border border-slate-100 hover:border-cyan-200 hover:shadow-md transition-all duration-200 overflow-hidden flex flex-col"
              >
                <div class="aspect-square bg-slate-50 flex items-center justify-center p-6 sm:p-8">
                  <img
                    src={p.image}
                    alt={p.name}
                    class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500"
                    style="mix-blend-mode:multiply;"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="p-4 border-t border-slate-100">
                  <div class="font-mono text-xs font-semibold text-cyan-600 mb-0.5">{p.capacity}</div>
                  <div class="font-display font-semibold text-slate-900 text-sm group-hover:text-cyan-700 transition-colors">{p.name}</div>
                  <div class="text-slate-400 text-xs mt-0.5 hidden sm:block line-clamp-1">{p.tagline}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
  <Footer />
</Layout>

<style>
  /* Size the product name so it always fits on a single line.
     --name-em is the name's approximate rendered width in em. */
  .product-title {
    font-size: min(76px, calc((100vw - 48px) / var(--name-em)));
  }
  @media (min-width: 1024px) {
    /* Two-column hero: title column is half the content width (max-w-7xl minus padding and gap). */
    .product-title {
      font-size: min(76px, calc((min(100vw, 1280px) - 128px) / 2 / var(--name-em)));
    }
  }

  /* Hide the thumbnail strip's scrollbar; the arrows are the scroll affordance. */
  .scrollbar-hide {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const mainImg = document.getElementById('product-main-img') as HTMLImageElement | null;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('[data-thumb]');
  thumbs.forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!mainImg || !btn.dataset.thumb) return;
      mainImg.src = btn.dataset.thumb;
      thumbs.forEach((b) => {
        b.classList.remove('ring-2');
        b.classList.add('opacity-70');
      });
      btn.classList.add('ring-2');
      btn.classList.remove('opacity-70');
      btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
    });
  });

  const strip = document.getElementById('thumb-strip');
  const prev = document.getElementById('thumb-prev');
  const next = document.getElementById('thumb-next');
  if (strip && prev && next) {
    const page = () => Math.max(strip.clientWidth * 0.8, 160);
    prev.addEventListener('click', () => strip.scrollBy({ left: -page(), behavior: 'smooth' }));
    next.addEventListener('click', () => strip.scrollBy({ left: page(), behavior: 'smooth' }));

    // Hide arrows that can't scroll any further (or both, if everything fits).
    const update = () => {
      const overflow = strip.scrollWidth > strip.clientWidth + 4;
      prev.classList.toggle('hidden', !overflow || strip.scrollLeft <= 4);
      next.classList.toggle('hidden', !overflow || strip.scrollLeft + strip.clientWidth >= strip.scrollWidth - 4);
    };
    strip.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }
</script>
