---
// Each icon is a custom accurate SVG — not a generic heroicon
// Icons use currentColor so they adapt to any container color
const rows = [
  {
    n: '01',
    metric: '200mm',
    title: 'Ultra-slim ceiling profile',
    detail: "Fits inside a standard false ceiling without modification. Nothing to see — not even a grille if you don't want one.",
    // Cross-section side view: structural slab → thin unit → false ceiling tile
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5">
      <rect x="1" y="1.5" width="22" height="3" rx="0.5" fill="currentColor" opacity="0.5"/>
      <rect x="3" y="6.5" width="18" height="4.5" rx="1" fill="currentColor"/>
      <line x1="7" y1="8.5" x2="7" y2="10.5" stroke="black" stroke-width="1" opacity="0.25"/>
      <line x1="10.5" y1="8.5" x2="10.5" y2="10.5" stroke="black" stroke-width="1" opacity="0.25"/>
      <line x1="14" y1="8.5" x2="14" y2="10.5" stroke="black" stroke-width="1" opacity="0.25"/>
      <line x1="17.5" y1="8.5" x2="17.5" y2="10.5" stroke="black" stroke-width="1" opacity="0.25"/>
      <rect x="1" y="13" width="22" height="2.5" rx="0.5" fill="currentColor" opacity="0.4"/>
      <line x1="13" y1="13" x2="13" y2="15.5" stroke="black" stroke-width="0.75" opacity="0.2"/>
    </svg>`,
  },
  {
    n: '02',
    metric: '1.8 m',
    title: 'Built-in condensate pump',
    detail: 'Pumps water up to 1.8 m so you can drain to any convenient point. No gravity slope required, no water tray to empty.',
    // Vertical pipe with water droplet at bottom being lifted to outlet at top
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5">
      <rect x="10" y="3" width="4" height="15" rx="2" fill="currentColor" opacity="0.25"/>
      <path d="M12 19 C12 19 8.5 15.5 8.5 13.5 C8.5 11.6 10.1 10 12 10 C13.9 10 15.5 11.6 15.5 13.5 C15.5 15.5 12 19 12 19Z" fill="currentColor" opacity="0.5"/>
      <circle cx="12" cy="4.5" r="2" fill="currentColor"/>
      <path d="M10.5 8 L12 5.5 L13.5 8" fill="currentColor"/>
      <path d="M7 21 Q12 19 17 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
      <path d="M6 23 Q12 21.5 18 23" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
    </svg>`,
  },
  {
    n: '03',
    metric: '360°',
    title: 'Whole-space coverage',
    detail: 'Ducted airflow treats every room, not just the one with the unit. One install, building-wide humidity control.',
    // Top-down floor plan: unit in center, 4 ducts radiating to corners of the space
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5">
      <rect x="1.5" y="1.5" width="21" height="21" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.6"/>
      <rect x="9" y="9" width="6" height="6" rx="1" fill="currentColor"/>
      <line x1="12" y1="9" x2="12" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="12" y1="15" x2="12" y2="21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="9" y1="12" x2="3" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="15" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="12" cy="3" r="1.25" fill="currentColor"/>
      <circle cx="12" cy="21" r="1.25" fill="currentColor"/>
      <circle cx="3" cy="12" r="1.25" fill="currentColor"/>
      <circle cx="21" cy="12" r="1.25" fill="currentColor"/>
    </svg>`,
  },
  {
    n: '04',
    metric: '39 dB',
    title: 'Near-silent operation',
    detail: 'Quieter than most split aircons. Runs continuously in the background without disrupting sleep or conversations.',
    // Speaker cone + only ONE tiny arc (indicating barely any sound)
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5">
      <path d="M4 9 L4 15 L7 15 L13 19 L13 5 L7 9 Z" fill="currentColor"/>
      <path d="M16 10.5 Q18 12 16 13.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" fill="none"/>
      <path d="M11 2 L11 22" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" opacity="0.15"/>
      <path d="M18 7 Q22 12 18 17" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" fill="none" opacity="0.2"/>
    </svg>`,
  },
  {
    n: '05',
    metric: 'WiFi',
    title: 'Tuya app + RS485 Modbus',
    detail: 'Consumer app for homes. RS485 Modbus for commercial BMS integration. One platform, any install context.',
    // Phone with WiFi signal arcs — represents Tuya app control
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5">
      <rect x="7" y="4" width="10" height="17" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <rect x="9" y="6.5" width="6" height="8" rx="0.5" fill="currentColor" opacity="0.3"/>
      <circle cx="12" cy="18" r="1" fill="currentColor"/>
      <path d="M9.5 5.5 Q12 3.5 14.5 5.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" fill="none" opacity="0.6"/>
      <path d="M8 4.5 Q12 1.5 16 4.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" fill="none" opacity="0.35"/>
    </svg>`,
  },
  {
    n: '06',
    metric: 'SG',
    title: "Engineered for Singapore's climate",
    detail: "Optimised for 80–90% outdoor RH, 28–33°C ambient. Effective dehumidification without a punishing power bill.",
    // Three humidity droplets with a temperature gauge — SG tropical climate
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5">
      <path d="M12 20 C12 20 6 14.5 6 10.5 C6 7.4 8.7 5 12 5 C15.3 5 18 7.4 18 10.5 C18 14.5 12 20 12 20Z" fill="currentColor" opacity="0.7"/>
      <path d="M5 11 C5 11 2 8.5 2 6.5 C2 5 3.3 4 5 4 C6.7 4 8 5 8 6.5 C8 8.5 5 11 5 11Z" fill="currentColor" opacity="0.4"/>
      <path d="M19 11 C19 11 16 8.5 16 6.5 C16 5 17.3 4 19 4 C20.7 4 22 5 22 6.5 C22 8.5 19 11 19 11Z" fill="currentColor" opacity="0.4"/>
      <circle cx="12" cy="11" r="2" fill="white" opacity="0.3"/>
    </svg>`,
  },
];
---

<section id="why-drytech" class="py-24 bg-dt-950 text-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">

    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-16" data-reveal>
      <div>
        <p class="text-[10px] font-mono tracking-[0.22em] uppercase text-cyan-500 mb-3">02 — Why DryTech</p>
        <h2 class="font-display font-bold text-white leading-tight" style="font-size:clamp(28px,4.5vw,52px);">
          Built for this climate.<br/>Built to disappear.
        </h2>
      </div>
    </div>

    <div class="divide-y divide-white/8">
      {rows.map((row) => (
        <div
          class="group flex items-center py-5 hover:bg-white/[0.02] -mx-6 px-6 transition-colors gap-5"
          data-reveal
        >
          <!-- Index -->
          <span class="text-[11px] font-mono text-white/25 shrink-0 w-6">{row.n}</span>

          <!-- Bubble icon -->
          <div class="w-11 h-11 rounded-full bg-cyan-500/12 border border-cyan-500/20 flex items-center justify-center text-cyan-400 shrink-0">
            <Fragment set:html={row.icon} />
          </div>

          <!-- Content: metric + divider + title/detail, all bounded by flex-1 min-w-0 -->
          <div class="flex-1 min-w-0 flex items-center gap-5">

            <!-- Metric: fixed width so separator stays at the same X across all rows -->
            <div class="shrink-0 w-[96px] whitespace-nowrap font-display font-black text-cyan-500 leading-none tabular-nums" style="font-size:clamp(14px,1.5vw,20px);">{row.metric}</div>

            <!-- Divider -->
            <div class="self-stretch w-px bg-white/10 shrink-0"></div>

            <!-- Title + detail: takes remaining space, wraps normally -->
            <div class="flex-1 min-w-0">
              <div class="font-display font-semibold text-white text-sm mb-1 group-hover:text-cyan-200 transition-colors">{row.title}</div>
              <div class="text-white/40 text-sm leading-relaxed">{row.detail}</div>
            </div>

          </div>
        </div>
      ))}
    </div>

  </div>
</section>
