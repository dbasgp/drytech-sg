---
import type { Product } from '../data/products';
import { waLink } from '../data/products';

interface Props {
  product: Product;
  index: number;
}
const { product, index } = Astro.props;
const enquireUrl = waLink(product.enquiryText);
const num = String(index + 1).padStart(2, '0');
---

<a
  href={enquireUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="product-row group flex items-center gap-4 px-4 py-4 rounded-xl border border-transparent hover:border-slate-200 hover:bg-slate-50 transition-all duration-150 cursor-pointer"
>
  <!-- Index -->
  <span class="text-[11px] font-mono text-slate-300 shrink-0 w-5">{num}</span>

  <!-- Image (mix-blend-mode:multiply knocks out white bg) -->
  <div class="shrink-0 w-14 h-14 flex items-center justify-center overflow-hidden">
    <img
      src={product.image}
      alt={product.name}
      class="w-full h-full object-contain"
      style="mix-blend-mode:multiply;"
      loading="lazy"
      decoding="async"
      width="56"
      height="56"
    />
  </div>

  <!-- Name + tagline -->
  <div class="flex-1 min-w-0">
    <div class="font-display font-semibold text-slate-900 text-sm group-hover:text-cyan-700 transition-colors truncate">{product.name}</div>
    <div class="text-xs text-slate-400 mt-0.5 truncate">{product.tagline}</div>
  </div>

  <!-- Capacity -->
  <div class="shrink-0 text-right hidden sm:block">
    <span class="font-mono text-sm font-semibold text-slate-700">{product.capacity}</span>
  </div>

  <!-- Enquire -->
  <div class="shrink-0 flex items-center gap-1 text-xs font-semibold text-cyan-600 group-hover:gap-2 transition-all whitespace-nowrap">
    Enquire
    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </div>
</a>
