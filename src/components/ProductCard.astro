---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}
const { product } = Astro.props;
---

<a
  href={`/products/${product.id}`}
  class="group bg-white rounded-2xl border border-slate-100 hover:border-cyan-200 hover:shadow-lg transition-all duration-300 overflow-hidden flex flex-col"
>
  <!-- Product image -->
  <div class="aspect-square bg-slate-50 flex items-center justify-center p-5 sm:p-7">
    <img
      src={product.image}
      alt={product.name}
      class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500"
      style="mix-blend-mode:multiply;"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Info -->
  <div class="p-3 sm:p-4 flex flex-col flex-1 border-t border-slate-100">
    <div class="font-mono text-[10px] sm:text-xs font-semibold text-cyan-600 mb-1">{product.capacity}</div>
    <div class="font-display font-semibold text-slate-900 text-xs sm:text-sm leading-snug mb-1 group-hover:text-cyan-700 transition-colors">{product.name}</div>
    <div class="text-slate-400 text-[11px] leading-snug line-clamp-2 flex-1 hidden sm:block">{product.tagline}</div>
    <div class="mt-2 sm:mt-3 flex items-center gap-1 text-[10px] sm:text-xs font-semibold text-cyan-600">
      Details →
    </div>
  </div>
</a>
