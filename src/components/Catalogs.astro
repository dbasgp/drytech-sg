---
// PDF files go in /public/catalogs/ — download them from dba.sg and update the paths here.
const catalogs = [
  {
    title: 'Ultra-Thin Ceiling Series',
    subtitle: 'DBA-UTC20 / UTC68 / UTC120',
    file: '/catalogs/dba-ultra-thin-ceiling.pdf',
    lines: ['UTC20', 'UTC68', 'UTC120'],
  },
  {
    title: 'Commercial Ceiling Series',
    subtitle: 'DBA-GEC68 / GEC145 / GEC280 / GEC400',
    file: '/catalogs/dba-commercial-ceiling.pdf',
    lines: ['GEC68LD-HP', 'GEC145LD-HP', 'GEC280LD', 'GEC400LD'],
  },
  {
    title: 'Restoration Series',
    subtitle: 'DBA-DH65 / GEX75 / GEX110',
    file: '/catalogs/dba-restoration.pdf',
    lines: ['DH65', 'GEX75', 'GEX110'],
  },
  {
    title: 'Industrial & Specialised',
    subtitle: 'Industrial · Humidity Control · Desiccant',
    file: '/catalogs/dba-industrial-specialised.pdf',
    lines: ['Industrial', 'Humidity Control', 'Desiccant'],
  },
];
---

<section id="catalogs" class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">

    <div class="max-w-2xl mb-12" data-reveal>
      <p class="text-xs font-semibold tracking-[0.16em] uppercase text-cyan-600 mb-3">Downloads</p>
      <h2 class="font-display font-bold text-4xl text-slate-900 leading-tight mb-4">
        Product catalogs
      </h2>
      <p class="text-slate-500 text-lg">
        Full specifications, dimensions and performance data for every DryTech dehumidifier line.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {catalogs.map(({ title, subtitle, file, lines }) => (
        <a
          href={file}
          target="_blank"
          rel="noopener noreferrer"
          download
          class="group bg-white rounded-2xl border border-slate-200 hover:border-cyan-200 hover:shadow-md p-6 flex flex-col transition-all duration-300"
        >
          <!-- PDF icon -->
          <div class="w-10 h-10 rounded-xl bg-cyan-50 group-hover:bg-cyan-100 flex items-center justify-center mb-4 transition-colors">
            <svg width="20" height="20" fill="none" stroke="#0891B2" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v6h6"/>
            </svg>
          </div>

          <h3 class="font-display font-semibold text-slate-900 text-sm mb-1">{title}</h3>
          <p class="text-slate-400 text-xs mb-4">{subtitle}</p>

          <!-- Model tags -->
          <div class="flex flex-wrap gap-1 mt-auto mb-4">
            {lines.map(l => (
              <span class="text-[10px] bg-slate-100 text-slate-500 px-2 py-0.5 rounded-full font-medium">{l}</span>
            ))}
          </div>

          <!-- Download label -->
          <div class="flex items-center gap-1.5 text-cyan-600 text-xs font-semibold group-hover:gap-2.5 transition-all">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4 4-4M4 20h16"/>
            </svg>
            Download PDF
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
