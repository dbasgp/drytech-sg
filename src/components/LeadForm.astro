---
import { contact } from '../data/products';
---

<section id="contact" class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: editorial copy -->
      <div data-reveal>
        <p class="text-[10px] font-mono tracking-[0.22em] uppercase text-cyan-600 mb-4">Get Started</p>
        <h2 class="font-display font-black text-slate-900 leading-[0.92] tracking-[-0.02em] mb-6" style="font-size:clamp(36px,6vw,72px);">
          Tell us<br/>your space.
        </h2>
        <p class="text-slate-500 text-base leading-relaxed max-w-md mb-10">
          Share the basic details below and we'll send you a no-obligation recommendation and rough estimate over WhatsApp within one business day.
        </p>

        <!-- Direct contact links -->
        <div class="space-y-4">
          <a
            href={`https://wa.me/${contact.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 group"
          >
            <div class="w-9 h-9 rounded-lg bg-green-50 group-hover:bg-green-100 flex items-center justify-center transition-colors shrink-0">
              <svg width="16" height="16" fill="#16a34a" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-slate-400 tracking-wide">WhatsApp</div>
              <div class="text-sm font-semibold text-slate-700 group-hover:text-green-700 transition-colors">{contact.whatsappDisplay}</div>
            </div>
          </a>

          <a href={`tel:${contact.hotline.replace(/\s/g,'')}`} class="flex items-center gap-3 group">
            <div class="w-9 h-9 rounded-lg bg-slate-100 group-hover:bg-slate-200 flex items-center justify-center transition-colors shrink-0">
              <svg width="16" height="16" fill="none" stroke="#475569" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-slate-400 tracking-wide">Hotline</div>
              <div class="text-sm font-semibold text-slate-700 group-hover:text-slate-900 transition-colors">{contact.hotline}</div>
            </div>
          </a>

          <a href={`mailto:${contact.email}`} class="flex items-center gap-3 group">
            <div class="w-9 h-9 rounded-lg bg-slate-100 group-hover:bg-slate-200 flex items-center justify-center transition-colors shrink-0">
              <svg width="16" height="16" fill="none" stroke="#475569" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-slate-400 tracking-wide">Email</div>
              <div class="text-sm font-semibold text-slate-700 group-hover:text-slate-900 transition-colors">{contact.email}</div>
            </div>
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="bg-white rounded-2xl border border-slate-200 p-8" data-reveal>
        <form id="lead-form" novalidate>
          <div class="space-y-5">

            <div>
              <label for="lf-name" class="block text-xs font-semibold text-slate-500 tracking-wide mb-1.5 uppercase">Name</label>
              <input
                id="lf-name"
                name="name"
                type="text"
                required
                placeholder="Your name"
                autocomplete="name"
                class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-cyan-500/30 focus:border-cyan-400 transition-colors"
              />
            </div>

            <div>
              <label for="lf-space" class="block text-xs font-semibold text-slate-500 tracking-wide mb-1.5 uppercase">Space type</label>
              <select
                id="lf-space"
                name="space"
                required
                class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-cyan-500/30 focus:border-cyan-400 transition-colors appearance-none bg-white"
              >
                <option value="" disabled selected>Select your space</option>
                <option value="HDB flat">HDB flat</option>
                <option value="condominium">Condominium</option>
                <option value="landed property">Landed property</option>
                <option value="office">Office</option>
                <option value="retail / F&B">Retail / F&amp;B</option>
                <option value="warehouse / factory">Warehouse / Factory</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="lf-size" class="block text-xs font-semibold text-slate-500 tracking-wide mb-1.5 uppercase">Approximate area (sqft)</label>
              <input
                id="lf-size"
                name="size"
                type="text"
                placeholder="e.g. 1,200 sqft"
                class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-cyan-500/30 focus:border-cyan-400 transition-colors"
              />
            </div>

            <div>
              <label for="lf-notes" class="block text-xs font-semibold text-slate-500 tracking-wide mb-1.5 uppercase">Anything else?</label>
              <textarea
                id="lf-notes"
                name="notes"
                rows="3"
                placeholder="Budget range, current problems, preferred installation timeline…"
                class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-cyan-500/30 focus:border-cyan-400 transition-colors resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-cyan-600 hover:bg-cyan-500 text-white font-semibold text-sm py-3.5 rounded-xl transition-colors flex items-center justify-center gap-2"
            >
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Send via WhatsApp
            </button>
            <p class="text-center text-xs text-slate-400">Opens WhatsApp with your details pre-filled. No spam, no forms lost in inbox.</p>
          </div>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name  = (document.getElementById('lf-name')  as HTMLInputElement).value.trim();
    const space = (document.getElementById('lf-space') as HTMLSelectElement).value;
    const size  = (document.getElementById('lf-size')  as HTMLInputElement).value.trim();
    const notes = (document.getElementById('lf-notes') as HTMLTextAreaElement).value.trim();

    const parts: string[] = ['Hi DryTech, I\'d like a free consultation for a ceiling dehumidifier.'];
    if (name)  parts.push(`Name: ${name}`);
    if (space) parts.push(`Space type: ${space}`);
    if (size)  parts.push(`Approximate area: ${size}`);
    if (notes) parts.push(`Notes: ${notes}`);

    const text = parts.join('\n');
    const url  = `https://wa.me/6589859886?text=${encodeURIComponent(text)}`;
    window.open(url, '_blank', 'noopener,noreferrer');
  });
</script>
