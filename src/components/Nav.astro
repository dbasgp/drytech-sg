---
import { contact, waLink } from '../data/products';

const consultLink = waLink("Hi DBA, I'd like a free consultation for a ceiling dehumidifier for my space.");
const navLinks = [
  { href: '#products',   label: 'Products',   n: '01' },
  { href: '#ceiling-dehumidifiers', label: 'How It Works', n: '02' },
  { href: '#calculator', label: 'Calculator', n: '03' },
  { href: '#contact',    label: 'Contact',    n: '04' },
];
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 nav-transparent">
  <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">

    <a href="/" class="flex items-center shrink-0" aria-label="DryTech.sg home">
      <img src="/images/drytech-logo.png" alt="DryTech" class="nav-logo-img h-6 w-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-7" aria-label="Main navigation">
      {navLinks.map(({ href, label, n }) => (
        <a href={href} class="nav-link group flex items-baseline gap-1.5 text-sm transition-opacity hover:opacity-70">
          <span class="text-[10px] font-mono nav-link-num opacity-50">{n}</span>
          <span class="font-medium">{label}</span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={consultLink}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 border nav-cta-border text-sm font-semibold px-4 py-2 rounded-full transition-colors nav-cta"
      >
        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Get a Quote
      </a>
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 nav-link"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden md:hidden bg-dt-950/98 px-6 py-5 border-t border-white/10"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <nav class="flex flex-col gap-4 mb-5">
      {navLinks.map(({ href, label, n }) => (
        <a href={href} class="flex items-center gap-2 text-sm font-medium text-white/70 hover:text-white transition-colors">
          <span class="text-[10px] font-mono text-white/30">{n}</span>
          {label}
        </a>
      ))}
    </nav>
    <a
      href={consultLink}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center gap-2 bg-cyan-600 text-white text-sm font-semibold px-5 py-3 rounded-full"
    >
      Get a Quote
    </a>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  function setNavStyle() {
    if (window.scrollY > 32) {
      nav?.classList.remove('nav-transparent');
      nav?.classList.add('nav-solid');
    } else {
      nav?.classList.remove('nav-solid');
      nav?.classList.add('nav-transparent');
    }
  }

  setNavStyle();
  window.addEventListener('scroll', setNavStyle, { passive: true });

  mobileBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    mobileBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.querySelectorAll('#mobile-menu a').forEach(a => {
    a.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileBtn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .nav-transparent .nav-link,
  .nav-transparent .nav-logo-primary { color: rgba(255,255,255,0.92); }
  .nav-transparent .nav-logo-secondary { color: rgba(255,255,255,0.38); }
  .nav-transparent .nav-cta { color: rgba(255,255,255,0.92); }
  .nav-transparent .nav-cta-border { border-color: rgba(255,255,255,0.25); }
  .nav-transparent .nav-cta:hover { border-color: rgba(255,255,255,0.55); }
  /* Logo: invert to white on dark nav, screen blend knocks out the black bg */
  .nav-transparent .nav-logo-img { filter: brightness(0) invert(1); mix-blend-mode: screen; }

  .nav-solid {
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 0 rgba(0,0,0,0.07);
  }
  .nav-solid .nav-link,
  .nav-solid .nav-logo-primary { color: #0f172a; }
  .nav-solid .nav-logo-secondary { color: #94a3b8; }
  .nav-solid .nav-cta { color: #0f172a; }
  .nav-solid .nav-cta-border { border-color: rgba(0,0,0,0.15); }
  .nav-solid .nav-cta:hover { border-color: rgba(0,0,0,0.35); }
  /* Logo: multiply knocks out white bg on white nav, black text stays */
  .nav-solid .nav-logo-img { filter: none; mix-blend-mode: multiply; }
</style>
