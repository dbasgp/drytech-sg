---
import { contact, productLines, waLink } from '../data/products';

const consultLink = waLink("Hi DryTech, I'd like a free consultation for a ceiling dehumidifier.");
---

<footer class="bg-dt-950 text-white">

  <!-- Large statement -->
  <div class="border-b border-white/8 py-16 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <p class="font-display font-black text-white/10 leading-[0.85] tracking-[-0.03em] select-none" style="font-size:clamp(44px,9vw,128px);" aria-hidden="true">
        HUMIDITY<br/>SOLVED.<br/><span style="-webkit-text-stroke:2px rgba(255,255,255,0.12);color:transparent;">INVISIBLY.</span>
      </p>
    </div>
  </div>

  <!-- Main footer grid -->
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 rounded bg-cyan-600 flex items-center justify-center shrink-0">
            <svg width="14" height="17" viewBox="0 0 12 15" fill="none" aria-hidden="true">
              <path d="M6 0.5C6 0.5 0.5 6 0.5 9.5a5.5 5.5 0 0011 0C11.5 6 6 0.5 6 0.5Z" fill="white"/>
            </svg>
          </div>
          <div class="leading-none">
            <div class="font-display font-bold text-sm text-white">DryTech</div>
            <div class="text-[8px] tracking-[0.2em] uppercase text-white/40">DRYTECH.SG</div>
          </div>
        </div>
        <p class="text-white/40 text-sm leading-relaxed mb-6 max-w-[200px]">
          Ceiling dehumidifiers for Singapore homes, offices and commercial spaces.
        </p>
        <a
          href={consultLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 bg-cyan-600/20 hover:bg-cyan-600/30 border border-cyan-600/30 text-cyan-400 text-xs font-semibold px-4 py-2 rounded-full transition-colors"
        >
          Get a free quote →
        </a>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-[10px] font-mono tracking-[0.2em] uppercase text-white/30 mb-4">Products</h3>
        <ul class="space-y-2.5">
          {productLines.map(line => (
            <li>
              <a href="#products" class="text-sm text-white/50 hover:text-white transition-colors">
                {line.name.replace(' Dehumidifiers','').replace(', Humidity Control & Desiccant','')}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-[10px] font-mono tracking-[0.2em] uppercase text-white/30 mb-4">Resources</h3>
        <ul class="space-y-2.5">
          <li><a href="#calculator" class="text-sm text-white/50 hover:text-white transition-colors">Humidity Calculator</a></li>
          <li><a href="#catalogs" class="text-sm text-white/50 hover:text-white transition-colors">Product Catalogs</a></li>
          <li><a href="#ceiling-dehumidifiers" class="text-sm text-white/50 hover:text-white transition-colors">How It Works</a></li>
          <li>
            <a href="https://www.dba.sg" target="_blank" rel="noopener noreferrer" class="text-sm text-white/50 hover:text-white transition-colors">
              dba.sg ↗
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-[10px] font-mono tracking-[0.2em] uppercase text-white/30 mb-4">Contact</h3>
        <ul class="space-y-3">
          <li>
            <a href={`https://wa.me/${contact.whatsapp}`} target="_blank" rel="noopener noreferrer" class="text-sm text-white/50 hover:text-white transition-colors flex items-center gap-2">
              <span class="text-green-500">●</span> {contact.whatsappDisplay}
            </a>
          </li>
          <li>
            <a href={`tel:${contact.hotline.replace(/\s/g,'')}`} class="text-sm text-white/50 hover:text-white transition-colors">{contact.hotline}</a>
          </li>
          <li>
            <a href={`mailto:${contact.email}`} class="text-sm text-white/50 hover:text-white transition-colors">{contact.email}</a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/8 py-5">
    <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-[11px] text-white/25">
      <span>&copy; {new Date().getFullYear()} DryTech.sg · dba.sg</span>
      <span class="font-mono">HUMIDITY SOLVED. INVISIBLY.</span>
    </div>
  </div>

</footer>
