---
const comparisons = [
  {
    label: 'Location',
    old: 'Sits on the floor or wall. Visible in the room.',
    dba: 'Above your false ceiling. Nothing visible from inside.',
  },
  {
    label: 'Coverage',
    old: 'One unit treats one room. Two rooms means two units.',
    dba: 'Ducted airflow reaches every room from a single install.',
  },
  {
    label: 'Upkeep',
    old: 'Fill the bucket. Empty it daily through humid season.',
    dba: 'Built-in pump drains to any point. No bucket, no schedule.',
  },
];
---

<section class="bg-dt-950" aria-label="Why ceiling dehumidification">
  <div class="max-w-7xl mx-auto px-6 py-24">

    <div class="mb-12">
      <p class="text-[10px] font-mono tracking-[0.22em] uppercase text-cyan-500/70 mb-4">01 — The difference</p>
      <h2 class="font-display font-bold text-white leading-tight" style="font-size:clamp(26px,4vw,52px);">
        Above the ceiling.<br/>Not on the floor.
      </h2>
    </div>

    <div class="hidden sm:grid sm:grid-cols-[120px_1fr_1fr] border-b border-white/8 pb-3 gap-0">
      <div></div>
      <div class="px-8 text-[10px] font-mono tracking-[0.18em] uppercase text-white/20">Standard portable</div>
      <div class="px-8 text-[10px] font-mono tracking-[0.18em] uppercase text-cyan-500/60">DBA ceiling unit</div>
    </div>

    <div class="divide-y divide-white/8">
      {comparisons.map((c) => (
        <div class="grid grid-cols-1 sm:grid-cols-[120px_1fr_1fr] gap-0">
          <div class="pt-7 sm:py-7 sm:flex sm:items-center">
            <span class="text-[10px] font-mono tracking-[0.18em] uppercase text-white/25">{c.label}</span>
          </div>
          <div class="mt-2 sm:mt-0 sm:py-7 sm:px-8 sm:border-l border-white/8 sm:flex sm:items-center">
            <p class="text-white/35 text-sm leading-relaxed">{c.old}</p>
          </div>
          <div class="mt-1 pb-7 sm:mt-0 sm:py-7 sm:px-8 sm:border-l border-white/8 sm:flex sm:items-center">
            <p class="text-white text-sm leading-relaxed">{c.dba}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
