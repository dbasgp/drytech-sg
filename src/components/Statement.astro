---
// Three-line problem statement building to the punch
// Proof-point icons are custom accurate SVGs in ICONIC bubble-circle style
const proofs = [
  {
    title: 'Hidden above the false ceiling',
    detail: '220 mm profile — sits inside the void. No grille, no box, nothing visible from the room.',
    // Cross-section: slab → unit → false ceiling tile
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5 text-white">
      <rect x="1" y="1.5" width="22" height="3" rx="0.5" fill="currentColor" opacity="0.6"/>
      <rect x="3" y="6.5" width="18" height="4.5" rx="1" fill="currentColor"/>
      <line x1="7"    y1="8.5" x2="7"    y2="10.5" stroke="rgba(6,13,24,0.35)" stroke-width="1"/>
      <line x1="10.5" y1="8.5" x2="10.5" y2="10.5" stroke="rgba(6,13,24,0.35)" stroke-width="1"/>
      <line x1="14"   y1="8.5" x2="14"   y2="10.5" stroke="rgba(6,13,24,0.35)" stroke-width="1"/>
      <line x1="17.5" y1="8.5" x2="17.5" y2="10.5" stroke="rgba(6,13,24,0.35)" stroke-width="1"/>
      <rect x="1" y="13" width="22" height="2.5" rx="0.5" fill="currentColor" opacity="0.5"/>
      <line x1="12" y1="13" x2="12" y2="15.5" stroke="rgba(6,13,24,0.2)" stroke-width="0.75"/>
    </svg>`,
  },
  {
    title: 'Ducts reach every room',
    detail: 'One unit distributes dry air across the entire floor plan. Whole-house humidity control from a single install.',
    // Floor plan top-down: unit in centre, 4 ducts to walls, outlets at each end
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5 text-white">
      <rect x="1.5" y="1.5" width="21" height="21" rx="1.5" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
      <rect x="9" y="9" width="6" height="6" rx="1" fill="currentColor"/>
      <line x1="12" y1="9"  x2="12" y2="3"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="12" y1="15" x2="12" y2="21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="9"  y1="12" x2="3"  y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="15" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="12" cy="3"  r="1.25" fill="currentColor"/>
      <circle cx="12" cy="21" r="1.25" fill="currentColor"/>
      <circle cx="3"  cy="12" r="1.25" fill="currentColor"/>
      <circle cx="21" cy="12" r="1.25" fill="currentColor"/>
    </svg>`,
  },
  {
    title: 'Drains itself, runs continuously',
    detail: 'Built-in pump lifts condensate 1.8 m to any drain point. No trays to empty, no manual resets.',
    // Pipe going up with condensate droplet at bottom → outlet dot at top
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5 text-white">
      <rect x="10" y="3" width="4" height="14" rx="2" fill="currentColor" opacity="0.3"/>
      <path d="M12 19 C12 19 8.5 15.5 8.5 13.5 C8.5 11.6 10.1 10 12 10 C13.9 10 15.5 11.6 15.5 13.5 C15.5 15.5 12 19 12 19Z" fill="currentColor" opacity="0.6"/>
      <circle cx="12" cy="4" r="2" fill="currentColor"/>
      <path d="M10.5 7.5 L12 4.5 L13.5 7.5" fill="currentColor"/>
      <path d="M7 21 Q12 19.5 17 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
    </svg>`,
  },
];
---

<section class="py-28 bg-white overflow-hidden" aria-label="Problem statement">
  <div class="max-w-7xl mx-auto px-6">

    <p class="text-[10px] font-mono tracking-[0.22em] uppercase text-slate-400 mb-12" data-reveal>
      THE PROBLEM WITH HUMIDITY IN SINGAPORE
    </p>

    <div class="border-t border-slate-100">
      <div class="flex items-start gap-6 py-7 border-b border-slate-100" data-reveal>
        <span class="text-[11px] font-mono text-slate-300 mt-1 shrink-0 w-6">01</span>
        <p class="font-display font-bold text-slate-200 leading-tight" style="font-size:clamp(20px,3.8vw,50px);">
          Walls sweat. Ceilings stain. Furniture warps. Mould spreads through the air-conditioning before you see it.
        </p>
      </div>

      <div class="flex items-start gap-6 py-7 border-b border-slate-100" data-reveal>
        <span class="text-[11px] font-mono text-slate-400 mt-1 shrink-0 w-6">02</span>
        <p class="font-display font-bold text-slate-400 leading-tight" style="font-size:clamp(20px,3.8vw,50px);">
          Portable units sit on the floor, fill up water trays, and only fix the one room they are in.
        </p>
      </div>

      <div class="flex items-start gap-6 py-7" data-reveal>
        <span class="text-[11px] font-mono text-cyan-500 mt-1 shrink-0 w-6">03</span>
        <p class="font-display font-bold text-slate-900 leading-tight" style="font-size:clamp(20px,3.8vw,50px);">
          DryTech solves it above your ceiling. <span class="text-cyan-600">Invisible. Continuous. Whole-space.</span>
        </p>
      </div>
    </div>

    <!-- Proof points with accurate bubble icons -->
    <div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-6 pt-8 border-t border-slate-100" data-reveal-group>
      {proofs.map(({ title, detail, icon }) => (
        <div class="flex gap-4 items-start" data-reveal-item>
          <!-- ICONIC-style bubble circle: filled cyan, white icon -->
          <div class="shrink-0 w-10 h-10 rounded-full bg-cyan-600 flex items-center justify-center shadow-sm mt-0.5">
            <Fragment set:html={icon} />
          </div>
          <div>
            <div class="text-sm font-semibold text-slate-900 mb-1">{title}</div>
            <div class="text-sm text-slate-500 leading-relaxed">{detail}</div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
