---
const proofs = [
  {
    title: 'Sits above your false ceiling',
    detail: '200mm profile — fits inside the void. No grille, no box, nothing visible from the room.',
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5 text-cyan-400">
      <rect x="1" y="1.5" width="22" height="3" rx="0.5" fill="currentColor" opacity="0.5"/>
      <rect x="3" y="6.5" width="18" height="4.5" rx="1" fill="currentColor"/>
      <line x1="7" y1="8.5" x2="7" y2="10.5" stroke="rgba(6,13,24,0.35)" stroke-width="1"/>
      <line x1="10.5" y1="8.5" x2="10.5" y2="10.5" stroke="rgba(6,13,24,0.35)" stroke-width="1"/>
      <line x1="14" y1="8.5" x2="14" y2="10.5" stroke="rgba(6,13,24,0.35)" stroke-width="1"/>
      <line x1="17.5" y1="8.5" x2="17.5" y2="10.5" stroke="rgba(6,13,24,0.35)" stroke-width="1"/>
      <rect x="1" y="13" width="22" height="2.5" rx="0.5" fill="currentColor" opacity="0.4"/>
    </svg>`,
  },
  {
    title: 'Ducts reach every room',
    detail: 'One unit distributes dry air across the whole floor plan. Whole-house control from a single install.',
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5 text-cyan-400">
      <rect x="1.5" y="1.5" width="21" height="21" rx="1.5" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
      <rect x="9" y="9" width="6" height="6" rx="1" fill="currentColor"/>
      <line x1="12" y1="9" x2="12" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="12" y1="15" x2="12" y2="21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="9" y1="12" x2="3" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="15" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="12" cy="3" r="1.25" fill="currentColor"/>
      <circle cx="12" cy="21" r="1.25" fill="currentColor"/>
      <circle cx="3" cy="12" r="1.25" fill="currentColor"/>
      <circle cx="21" cy="12" r="1.25" fill="currentColor"/>
    </svg>`,
  },
  {
    title: 'Drains itself, runs non-stop',
    detail: 'Built-in pump lifts condensate 1.8m to any drain. No trays to empty, no manual resets.',
    icon: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="w-5 h-5 text-cyan-400">
      <rect x="10" y="3" width="4" height="14" rx="2" fill="currentColor" opacity="0.3"/>
      <path d="M12 19 C12 19 8.5 15.5 8.5 13.5 C8.5 11.6 10.1 10 12 10 C13.9 10 15.5 11.6 15.5 13.5 C15.5 15.5 12 19 12 19Z" fill="currentColor" opacity="0.6"/>
      <circle cx="12" cy="4" r="2" fill="currentColor"/>
      <path d="M10.5 7.5 L12 4.5 L13.5 7.5" fill="currentColor"/>
      <path d="M7 21 Q12 19.5 17 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
    </svg>`,
  },
];
---

<section class="bg-dt-950 overflow-hidden" aria-label="Problem statement">
  <div class="max-w-7xl mx-auto px-6 py-24">

    <!-- Three-statement narrative -->
    <div class="border-t border-white/8">

      <div class="flex items-start gap-6 py-8 border-b border-white/8">
        <span class="text-[11px] font-mono text-white/20 mt-1 shrink-0 w-6">01</span>
        <p class="font-display font-bold text-white/35 leading-tight" style="font-size:clamp(20px,3.5vw,46px);">
          Walls sweat. Ceilings stain. Furniture warps. Mould spreads through the air-conditioning before you see it.
        </p>
      </div>

      <div class="flex items-start gap-6 py-8 border-b border-white/8">
        <span class="text-[11px] font-mono text-white/30 mt-1 shrink-0 w-6">02</span>
        <p class="font-display font-bold text-white/55 leading-tight" style="font-size:clamp(20px,3.5vw,46px);">
          Portable units sit on the floor, fill up water trays, and only fix the one room they're in.
        </p>
      </div>

      <div class="flex items-start gap-6 py-8">
        <span class="text-[11px] font-mono text-cyan-500 mt-1 shrink-0 w-6">03</span>
        <p class="font-display font-bold text-white leading-tight" style="font-size:clamp(20px,3.5vw,46px);">
          DBA solves it above your ceiling. <span class="text-cyan-400">Invisible. Continuous. Whole-space.</span>
        </p>
      </div>

    </div>

    <!-- Proof points -->
    <div class="mt-14 pt-10 border-t border-white/8 grid grid-cols-1 sm:grid-cols-3 gap-8">
      {proofs.map(({ title, detail, icon }) => (
        <div class="flex gap-4 items-start">
          <div class="shrink-0 w-10 h-10 rounded-full bg-cyan-500/12 border border-cyan-500/20 flex items-center justify-center mt-0.5">
            <Fragment set:html={icon} />
          </div>
          <div>
            <div class="text-sm font-semibold text-white mb-1">{title}</div>
            <div class="text-sm text-white/40 leading-relaxed">{detail}</div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
