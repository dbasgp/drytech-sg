---
import { contact, waLink } from '../data/products';

const quoteLink = waLink("Hi DBA, I'd like a free consultation and quote for a ceiling dehumidifier.");
const calcLink = contact.calculatorUrl;

const droplets = [
  { x: 8,  y: 14, s: 5 }, { x: 20, y: 55, s: 4 }, { x: 14, y: 78, s: 6 },
  { x: 70, y: 20, s: 5 }, { x: 80, y: 60, s: 7 }, { x: 88, y: 40, s: 4 },
  { x: 92, y: 75, s: 5 }, { x: 55, y: 82, s: 4 }, { x: 45, y: 35, s: 6 },
];
---

<section id="hero" class="relative min-h-screen bg-dt-950 overflow-hidden flex flex-col" aria-label="Hero">

  <!-- Subtle dot grid -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background-image:radial-gradient(circle,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:28px 28px;"
  ></div>

  <!-- Floating droplets (left half only so they don't overlap image) -->
  {droplets.slice(0, 5).map((d) => (
    <div
      class="hero-droplet absolute rounded-full bg-cyan-400/20 pointer-events-none"
      aria-hidden="true"
      style={`left:${Math.min(d.x, 44)}%;top:${d.y}%;width:${d.s}px;height:${d.s}px;opacity:0;`}
    />
  ))}

  <!-- House PNG: absolute right side — shows sm (640px) and up, responsive top/width -->
  <div class="absolute right-0 bottom-0 hidden sm:flex items-end justify-end z-0 sm:w-[52%] sm:top-[28%] lg:w-[56%] lg:top-[36%]" aria-hidden="true">
    <img
      src="/images/house-cutaway.png"
      alt="Ceiling dehumidifier whole-house ducting system"
      class="hero-image w-full object-contain object-bottom"
      loading="eager"
      decoding="async"
      width="3456"
      height="2158"
    />
  </div>

  <!-- Content: headline full-width, then left-column text below -->
  <div class="relative z-10 flex-1 flex flex-col max-w-7xl mx-auto w-full px-8 sm:px-12 pt-28 pb-16">

    <!-- Headline — full container width, no column constraint -->
    <div class="font-display font-extrabold leading-[0.85]">
      <div class="overflow-hidden">
        <div class="hero-word text-white block" style="font-size:clamp(28px,11vw,126px);">HUMIDITY</div>
      </div>
      <div class="overflow-hidden">
        <div class="hero-word text-white block" style="font-size:clamp(28px,11vw,126px);">SOLVED.</div>
      </div>
      <div class="overflow-hidden">
        <div
          class="hero-word block"
          style="font-size:clamp(28px,11vw,126px);color:transparent;-webkit-text-stroke:2px #06b6d4;"
        >INVISIBLY.</div>
      </div>
    </div>

    <!-- Mobile hero image: stacked below headline on phones (<640px) -->
    <div class="sm:hidden relative mt-6 h-[58vw] max-h-64" aria-hidden="true">
      <img
        src="/images/house-cutaway.png"
        alt=""
        class="hero-image absolute inset-0 w-full h-full object-contain object-center"
        loading="eager"
        decoding="async"
      />
    </div>

    <!-- Subtitle + CTAs + Trust — constrained on tablet+ so image doesn't overlap -->
    <div class="sm:mt-auto pt-8 sm:pt-12 sm:max-w-[52%] lg:max-w-[42%]">
      <p
        class="hero-sub text-white/50 text-base sm:text-lg leading-relaxed mb-7"
      >
        Ceiling-mounted dehumidifiers that live above your false ceiling. No floor units. No wall boxes. Nothing visible from the room.
      </p>

      <div class="hero-ctas flex flex-wrap gap-3">
        <a
          href={quoteLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-6 py-3 rounded-full transition-colors"
        >
          <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Free Quote on WhatsApp
        </a>
        <a
          href={calcLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-white/20 hover:border-white/45 text-white/75 hover:text-white text-sm font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Size calculator →
        </a>
      </div>

      <!-- Trust bar -->
      <div class="hero-trust flex flex-wrap items-center gap-x-6 gap-y-3 mt-10 pt-7 border-t border-white/10">
        <div>
          <div class="font-display font-bold text-white tabular-nums" style="font-size:clamp(16px,1.8vw,24px);">20+</div>
          <div class="text-white/30 text-[10px] tracking-[0.14em] uppercase mt-0.5">Years SG</div>
        </div>
        <div class="w-px h-6 bg-white/12 hidden sm:block"></div>
        <div>
          <div class="font-display font-bold text-white tabular-nums" style="font-size:clamp(16px,1.8vw,24px);">20–400</div>
          <div class="text-white/30 text-[10px] tracking-[0.14em] uppercase mt-0.5">L/day</div>
        </div>
        <div class="w-px h-6 bg-white/12 hidden sm:block"></div>
        <div>
          <div class="font-display font-bold text-white tabular-nums" style="font-size:clamp(16px,1.8vw,24px);">39 dB</div>
          <div class="text-white/30 text-[10px] tracking-[0.14em] uppercase mt-0.5">Quiet</div>
        </div>
        <div class="w-px h-6 bg-white/12 hidden sm:block"></div>
        <div>
          <div class="font-display font-bold text-white tabular-nums" style="font-size:clamp(16px,1.8vw,24px);">1.8 m</div>
          <div class="text-white/30 text-[10px] tracking-[0.14em] uppercase mt-0.5">Pump lift</div>
        </div>
      </div>
    </div>

  </div>

  <!-- Scroll cue -->
  <div class="scroll-indicator relative z-10 flex justify-center pb-8 shrink-0" aria-hidden="true">
    <div class="w-px h-10 bg-gradient-to-b from-white/25 to-transparent"></div>
  </div>

</section>
